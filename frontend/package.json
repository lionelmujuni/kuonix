{
  "name": "Kuonix",
  "version": "1.0.0",
  "description": "Batch image correction and grouping tool with limited editing capablities",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "image",
    "batch",
    "correction",
    "electron",
    "photo",
    "color"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "electron": "^29.4.6",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "electron-sudo": "^4.0.12",
    "gsap": "^3.15.0",
    "sudo-prompt": "^9.2.1",
    "tree-kill": "^1.2.2"
  }
}
