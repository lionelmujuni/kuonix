{
  "name": "Kuonix",
  "version": "1.0.0",
  "description": "Batch image correction and grouping tool with limited editing capablities",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "test": "vitest run",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.kuonix.app",
    "productName": "Kuonix",
    "directories": {
      "output": "../release"
    },
    "files": [
      "**/*",
      "kuonix.jar",
      "!jre/**",
      "!tests/**",
      "!*.test.js",
      "!vitest.config.js",
      "!jsconfig.json"
    ],
    "asarUnpack": [
      "kuonix.jar"
    ],
    "extraResources": [
      {
        "from": "jre/",
        "to": "jre/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/appicon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/appicon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/appicon.png"
    }
  },
  "keywords": [
    "image",
    "batch",
    "correction",
    "electron",
    "photo",
    "color"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "jsdom": "^29.0.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "electron-sudo": "^4.0.12",
    "sudo-prompt": "^9.2.1",
    "tree-kill": "^1.2.2"
  }
}
